@startuml
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Consolas
skinparam defaultFontSize 11

title 帧循环流程 (渲染 + 事件)

|#FFF3E0| 事件处理 |
start
:Win32 消息循环 GetMessageW;
:Win32::handle_message(msg);
:Platform::translate_event() WM_* -> Event;
:MsgPump::push_msg(event) (SPSC);
:MsgPump::msg_loop() (独立线程);
:EventRouter::dispatch(event);
:std::visit 按事件类型分派;
if (事件类型) then (鼠标/键盘)
  :Mouse::handle 或 Keyboard::handle;
  :HitTester::hit_test(mouse);
  if (命中 Widget?) then (是)
    :Widget::input(context, event);
  else (否)
  endif
else (ResizeEvent)
  :RenderScheduler::set_pending_size(w, h);
else (DpiChangeEvent)
  :Backend::set_dpi(dpi);
  :Mouse::set_dpi(dpi);
else (ThemeChangedEvent)
  :ColorScheme::light/dark(accent);
  :更新 Context::scheme;
else (DestroyEvent)
  :Engine::clear();
endif
:InvalidationTracker::mark_dirty();
:RenderScheduler::request_frame();

|#F3E5F5| 渲染帧 |
:Engine::render_frame();
:RenderScheduler::consume_resize();
if (有 pending resize?) then (是)
  :Backend::resize(width, height);
else (否)
endif
:Backend::begin();

|#E8F5E9| Phase 1: 全树布局 |
:root->layout(viewport, context);
:Widget 根据 SizeStyle 计算 bounds;
if (容器 Widget?) then (是)
  :遍历子节点分配位置\n并递归调用 layout();
else (否)
endif
if (Center?) then (是)
  :子节点自然尺寸 -> 居中放置;
endif

|#E0F2FE| Phase 2: 递归绘制 |
:root->draw(bounds, context, backend);
:visit_children 递归;
repeat
  :child->draw(child_bounds, context, backend);
repeat while (还有子节点?) is (是)
->no;

|#F5F5F5| 收尾 |
:Backend::end() Present;
:InvalidationTracker::clear();
stop
@enduml

@startuml
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Consolas
skinparam defaultFontSize 11

title Widget 生命周期 (创建 + 重建)

|#E0F2FE| 初始化 |
start
:Engine::set_root_widget<T>(args...);
:make_shared<T>(context, args...);
:TreeManager::set_root(context, widget);
:WidgetBuilder::build(context);
note right: 注册所有 Widget\n到 TreeManager 映射

|#F3E5F5| 运行时 - 子节点变动 |
:build<T>() 创建子 Widget;
if (children_ 是空的?) then (是)
  :直接设为 shared_ptr;
else (已有子节点)
  :转为 list 追加;
endif
:widget_tree_changed 回调;
:Engine::rebuild();
note right: 清空 id/index 映射\n重新注册全树

|#FCE4EC| 重建阶段 |
:TreeManager::clear();
:清空 id_widgets_、index_widgets_;
:index_count = 0;
:register_widget(root);
repeat
  :register_widget(child);
  :child->build(context);
repeat while (还有子 Widget?) is (是)
->no;

|#F5F5F5| 就绪 |
:RenderScheduler::request_frame();
note right: 渲染线程唤醒\n执行 layout + draw
stop
@enduml
