@startuml
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Consolas
skinparam defaultFontSize 11
skinparam packageBorderColor #999999

title NekoUI 架构总览

package "1. 平台抽象层\nneko::platform" {
  class Platform <<singleton>> {
    + translate_event() -> Event
    + query_theme() -> Event
    + ime_*
    + show/hide/close...
  }
  class Event <<variant>> {
    MouseMoveEvent
    MouseButtonEvent
    KeyEvent
    CharEvent
    ResizeEvent
    DpiChangeEvent
    ThemeChangedEvent
    DestroyEvent
  }
  class Win32 {
    - WNDCLASS
    - HWND
    + handle_message()
    + get_theme_from_registry()
  }

  Platform --> Event : translate
  Win32 -up-|> Platform
}

package "2. 渲染后端\nneko::backend" {
  class Backend <<abstract>> {
    + {abstract} begin() / end()
    + {abstract} draw_rect_fill()
    + {abstract} draw_rect()
    + {abstract} draw_line()
    + {abstract} draw_circle_fill()
    + {abstract} draw_text()
    + {abstract} resize()
    + {abstract} set_dpi()
  }
  class DirectX11 {
    - D3D11Device / Context / SwapChain
    - ID3D11VertexShader
    - ID3D11PixelShader
    - stb_truetype 图集
    + 完整实现所有 Backend 接口
  }

  DirectX11 -up-|> Backend
}

package "3. 输入设备\nneko::device" {
  class Mouse {
    - DPI scale
    + is_inside(rect) : bool
    + is_inside(circle) : bool
    + is_inside(rrect) : bool
    + is_inside(polygon) : bool
    + left_clicked() / released()
  }
  class Keyboard {
    - modifier state
    + just_pressed(key) : bool
    + just_released(key) : bool
    + char_buffer[16]
  }
}

package "4. 引擎核心\nneko::engine" {
  class Engine <<facade>> {
    + set_root_widget<T>()
    + render_frame()
    + rebuild()
    - clear()
  }

  class Context {
    + mark_dirty / widget_dirty
    + anim_inc / anim_dec
    + widget_tree_changed
    + mouse / keyboard (weak)
    + root (weak)
    + scheme : ColorScheme
    + native_handle
  }

  class Renderer {
    + render(rect, context, backend)
    - tree_ : TreeManager&
  }

  class TreeManager {
    + root_ : atomic<shared_ptr>
    + focused_ : atomic<weak_ptr>
    + mutex_ : shared_mutex
    + register_widget()
    + next_focus() / prev_focus()
  }

  class HitTester {
    + hit_test(mouse) -> shared_ptr
    - tree_ : TreeManager&
    - test_recursive()
  }

  class WidgetBuilder {
    + build(context)
    - tree_ : TreeManager&
    - register_widget()
  }

  class EventRouter {
    + dispatch(event)
    - handle_input()
    - handle_resize()
    - handle_dpi_change()
    - handle_theme_change()
    - handle_destroy()
  }

  class InvalidationTracker {
    + dirty_ : atomic<bool>
    + animation_ : atomic<int>
    + mark_dirty()
    + needs_frame() -> bool
    + consume_dirty_list()
  }

  class MsgPump {
    - ring_buffer[32] : SPSC
    + push_msg(event)
    + msg_loop()
    + stop()
  }

  class RenderScheduler {
    + request_frame()
    + set_pending_size()
    + pending_size() -> Size
    + consume_resize() -> optional
    - render_thread : jthread
  }

  class WidgetVisitor <<template>> {
    + visit_children(widget, visitor)
    - 分发四种 MutableWidget 变体
  }

  Engine *-- Context
  Engine *-- Renderer
  Engine *-- TreeManager
  Engine *-- HitTester
  Engine *-- WidgetBuilder
  Engine *-- EventRouter
  Engine *-- InvalidationTracker
  Engine *-- MsgPump
  Engine *-- RenderScheduler
  Engine o-- Mouse
  Engine o-- Keyboard
  Engine o-- Backend
}

package "5. Widget 系统\nneko::widget" {
  abstract class Widget {
    + {abstract} layout(rect, context)
    + {abstract} draw(rect, context, backend)
    + {abstract} build(context)
    + {abstract} event(context)
    + {abstract} input(context, event)
    + {abstract} hit_test(mouse) : bool
    # bounds : Vec4I
    # context_ : Context*
    - children_ : MutableWidget
    - z_index_ / id_ / path_
    + build<T>(args...) -> T&
    + children(fn)
    + parent() -> Widget*
  }

  class Button {
    + layout() : SizeStyle -> 固定/填充
    + draw() : 背景 + 边框 + 文字
    + input() : 点击 -> on_click
    + hit_test() : is_inside
    - text_ : string
    - on_click_ : function
  }

  class Column {
    + layout() : 垂直栈式排列子节点
    + draw() : 背景
    + hit_test() : is_inside
  }

  class Row {
    + layout() : 水平排列子节点
    + draw() : 背景
    + hit_test() : is_inside
  }

  class Center {
    + layout() : 子 Widget 居中放置
    + draw() : 背景
    + hit_test() : is_inside
  }

  class MutableWidget <<variant>> {
    monostate
    shared_ptr<Widget>
    list<MutableWidget>
    vector<MutableWidget>
  }

  Button -up-|> Widget
  Column -up-|> Widget
  Row -up-|> Widget
  Center -up-|> Widget
  Widget *-- MutableWidget
  MutableWidget --> Widget : children
}

package "6. 样式系统\nneko::style" {
  class ColorScheme {
    + {static} light(seed) -> 36-tone
    + {static} dark(seed) -> 36-tone
    - primary / on_primary / ...
    - surface / background / ...
    - error / on_error / ...
    - HCT 色彩引擎
  }

  class BackgroundStyle <<mixin>> {
    # background_ : Background
  }
  class SizeStyle <<mixin>> {
    # size_ : Size (size/margin/padding)
  }
  class BorderStyle <<mixin>> {
    # border_ : Border (size/color)
  }
  class TextStyle <<mixin>> {
    # text_color_ : Color
    # font_size_ : float
  }
}

' ==================== 跨层关系 ====================

' 引擎 → 外部
Engine --> Platform : get event
Engine --> MsgPump : push_msg

' 帧循环
Engine --> RenderScheduler : request_frame
RenderScheduler --> Renderer : render_frame()
Renderer --> Widget : layout() + draw()
Renderer --> Backend : draw primitives

' 事件分发
MsgPump --> EventRouter : dispatch
EventRouter --> HitTester : hit_test
HitTester --> Widget : input() 命中分发
EventRouter --> Mouse : handle event
EventRouter --> Keyboard : handle event
EventRouter --> Backend : resize / dpi
EventRouter --> RenderScheduler : set_pending_size

' 构建
WidgetBuilder --> TreeManager : register_widget
WidgetBuilder --> Widget : build() 递归

' 脏标记
InvalidationTracker --> Context : needs_frame -> request_frame
Widget --> Context : mark_dirty (via callback)

' Widget -> 样式 mixin
Button ..> BackgroundStyle : <<mixin>>
Button ..> SizeStyle : <<mixin>>
Button ..> BorderStyle : <<mixin>>
Button ..> TextStyle : <<mixin>>
Column ..> BackgroundStyle
Column ..> SizeStyle
Row ..> BackgroundStyle
Row ..> SizeStyle
Center ..> BackgroundStyle

' ==================== 设计模式标注 ====================

note right of "4. 引擎核心"
  <b>外观模式</b>: Engine 统一调度全部子系统
  <b>观察者模式</b>: InvalidationTracker 脏标记推送
  <b>代理模式</b>: MsgPump 线程安全事件代理
  <b>工厂方法</b>: set_root_widget<T>()
  <b>访问者模式</b>: WidgetVisitor::visit_children
  <b>组合模式</b>: Widget 树 + MutableWidget
end note

note right of Backend
  <b>策略模式</b>: Backend 抽象接口，
  DirectX11 具体实现
end note

note right of Platform
  <b>模板方法</b>: Platform 基类定义，
  Win32 具体实现
end note

note right of Center
  <b>布局下放架构</b>:
  Widget 通过 layout() 自己计算 bounds
  Renderer 两阶段: layout + draw
  Center 不再绕过 Renderer
  消除双重绘制
end note

note right of ColorScheme
  <b>Material You HCT</b>
  sRGB <-> XYZ <-> CAM16 <-> HCT
  牛顿迭代求解
  36 色调色板
end note

@enduml
