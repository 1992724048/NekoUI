@startuml
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Consolas
skinparam defaultFontSize 11

title NekoUI 架构总览

package "1. 平台抽象层" {
  class Platform <<singleton>>
  class Event <<value>>
  class Win32
  Platform --> Event : translate
  Win32 -up-|> Platform
}

package "2. 渲染后端" {
  class Backend <<abstract>>
  class DirectX11
  DirectX11 -up-|> Backend
}

package "3. 输入设备" {
  class Mouse
  class Keyboard
}

package "4. 引擎核心" {
  class Engine <<facade>>
  class Context
  class Renderer
  class TreeManager
  class HitTester
  class WidgetBuilder
  class EventRouter
  class InvalidationTracker
  class MsgPump
  class RenderScheduler
  class WidgetVisitor <<template>>

  Engine *-- Context
  Engine *-- Renderer
  Engine *-- TreeManager
  Engine *-- HitTester
  Engine *-- WidgetBuilder
  Engine *-- EventRouter
  Engine *-- InvalidationTracker
  Engine *-- MsgPump
  Engine *-- RenderScheduler
  Engine o-- Mouse
  Engine o-- Keyboard
  Engine o-- Backend
}

package "5. Widget 系统" {
  abstract class Widget {
    + layout()
    + draw()
    + build()
    + event()
    + input()
    + hit_test()
  }
  class Button
  class Column
  class Row
  class Center

  Button -up-|> Widget
  Column -up-|> Widget
  Row -up-|> Widget
  Center -up-|> Widget
}

package "6. 样式系统" {
  class ColorScheme
  class BackgroundStyle
  class SizeStyle
  class BorderStyle
  class TextStyle
}

' 组件间关系
Engine --> Platform : 获取事件
Engine --> MsgPump : 推送事件
Engine --> RenderScheduler : request_frame
RenderScheduler --> Renderer : render_frame()
Renderer --> Widget : layout + draw
Renderer --> Backend : draw
MsgPump --> EventRouter : dispatch
EventRouter --> HitTester : hit_test
HitTester --> Widget : input()
WidgetBuilder --> TreeManager : register
WidgetBuilder --> Widget : build()
InvalidationTracker --> Context : needs_frame

' 设计模式标注
note right of "4. 引擎核心"
  **外观模式**: Engine 统一调度
end note

note right of EventRouter
  **访问者模式**: std::visit 分派事件
end note

note right of InvalidationTracker
  **观察者模式**: 脏标记通知
end note

note right of MsgPump
  **代理模式**: 线程安全事件代理
end note

note right of Renderer
  **两阶段渲染**: layout() + draw()
end note

@enduml
